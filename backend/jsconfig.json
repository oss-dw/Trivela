{
  "compilerOptions": {
    "checkJs": false,
    "strict": false,
    "noEmit": true,
    "allowJs": true,
    "module": "node16",
    "moduleResolution": "node16",
    "target": "ES2022",
    "lib": ["ES2022"],
    "skipLibCheck": true
  },
  "include": ["src/**/*.js"],
  "exclude": ["node_modules"]
}
