{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "test": "node --test src/**/*.test.js",
    "test:integration": "node --test src/integration/**/*.test.js",
