  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1057.0",
    "@stellar/stellar-sdk": "^14.0.0",
    "better-sqlite3": "^11.0.0",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "ioredis": "^5.4.0",
    "multer": "^2.1.1",
    "pino": "^9.0.0",
    "supertest": "^7.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@readme/openapi-parser": "^2.6.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.0",
    "ajv": "^8.17.0",
    "js-yaml": "^4.1.0",
    "nodemon": "^3.1.0",
    "typescript": "^5.0.0"
